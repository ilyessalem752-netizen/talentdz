NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/talentdz

# JWT
JWT_SECRET=change_this_to_a_very_long_random_string_in_production
JWT_REFRESH_SECRET=another_very_long_random_string_for_refresh_tokens
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Client origin(s) — comma-separated, no trailing slashes
# Production example:
# CLIENT_URL=https://talent-dz.netlify.app
# Multiple origins:
# CLIENT_URL=https://talent-dz.netlify.app,https://staging.talent-dz.netlify.app
CLIENT_URL=http://localhost:5173

# Admin account — auto-created on startup if no admin exists in the DB
# Set these on Render to use custom credentials instead of the demo defaults
ADMIN_EMAIL=admin@talentdz.dz
ADMIN_PASSWORD=Admin1234!

# Uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe_app
EMAIL_FROM=TalentDZ <noreply@talentdz.dz>